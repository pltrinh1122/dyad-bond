#!/usr/bin/env bash
# .githooks/pre-push â€” dyad-bond portable choke-point enforcement (SUBSTRATE-AGNOSTIC)
#
# WHY (2026-07-04, Operator d-land â€” the common-friction resolution across `agy`/`claude`):
#   `bin/git.sh` declares the push policy (ALLOWED_OPS / PROTECTED_BRANCHES / FORCE_FLAGS) but is a
#   CHOKE-POINT, not a gate â€” its integrity depends on the harness DENYING raw `git push` so it can't be
#   bypassed. That deny lives in `.claude/settings.json` (Claude-ONLY). On `agy`/Gemini there is no such
#   deny, so the choke-point would fail OPEN, and SILENTLY â€” a live violation of `bond:substrate-agnostic`
#   clause-2 (fail loud, never counterfeit-green). This hook moves the load-bearing guard OUT of per-harness
#   config and INTO git itself: it fires on EVERY `git push` on ANY substrate, raw or wrapped.
#
# WHAT IT GUARDS: it REFUSES *any direct push to a PROTECTED branch* (main) â€” force, non-fast-forward,
#   plain fast-forward, or deletion alike. `main` lands ONLY via branchâ†’PRâ†’Operator-merge (server-side);
#   the Agent never legitimately pushes main from a local clone, on ANY substrate. Normal feature-branch
#   pushes (incl. force-with-lease to a feature branch) PASS untouched. It does NOT enforce "must go
#   through bin/git.sh" â€” that stays the PR discipline + (on Claude) the classifier.
#
# WIDENED 2026-07-06 (dyad-rt principle adopt, Operator-ratified): previously this guarded only the
#   irreversible class (force/delete of main) and DELEGATED "never push main at all" to the native
#   substrate (Claude classifier / settings.json â€” absent on agy, so it failed OPEN there). Adopting
#   cairn's `dyad-rt` invariant â€” *the Dyad runtime, not the native substrate, owns permissioning* â€” that
#   whole guarantee now lives HERE, portably (fires on agy + raw `git push` too). REJECTED from dyad-rt:
#   its `--dangerously-skip-permissions` (the native gate stays as a backstop) + its scripted autonomous
#   merge (bond:no-self-ratify â€” the merge gate is NEVER scripted). â†’ dialectic/substrate-access.md
#   Â§Dyad-runtime permissioning.
#
# CAVEAT (honest, not hidden): `git push --no-verify` bypasses this hook. That is a DELIBERATE, VISIBLE
#   act (fail-loud, not silent) â€” the opposite of the silent config-absence this replaces. Acceptable.
#
# INSTALL (substrate-agnostic, one-time per clone â€” NOT automatic on clone):
#   git config core.hooksPath .githooks
#   `bin/standup.sh` checks this every stand-up (d-start) and SURFACES LOUD if unset â€” so a substrate
#   where the guard isn't active announces it, rather than running ungated in silence.

set -euo pipefail

PROTECTED_RE='^refs/heads/(main)$'          # keep in sync with bin/git.sh PROTECTED_BRANCHES
Z40=0000000000000000000000000000000000000000

# pre-push stdin: <local_ref> SP <local_sha> SP <remote_ref> SP <remote_sha>  (one line per ref)
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ "$remote_ref" =~ $PROTECTED_RE ]] || continue          # only guard protected branches

  # Deletion of a protected branch (local side is all-zeros).
  if [[ "$local_sha" == "$Z40" ]]; then
    printf 'pre-push: REFUSED â€” deletion of protected branch %s (dyad-bond memory-durability guard).\n' \
      "$remote_ref" >&2
    exit 1
  fi

  # ANY direct push to a protected branch is refused (dyad-rt adopt) â€” not only force/delete. `main`
  # lands via branchâ†’PRâ†’Operator-merge (server-side); a local push to main is never legitimate here.
  # Force / non-fast-forward are a strict subset, folded into the message below (their old dedicated
  # branch is subsumed). This is the load-bearing move: the no-direct-push-main permission now lives in
  # git, portable across substrates, instead of being delegated to the (Claude-only) native gate.
  if git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
    kind='(fast-forward)'
  else
    kind='(NON-fast-forward / force)'
  fi
  printf 'pre-push: REFUSED â€” direct push to protected branch %s %s.\n' "$remote_ref" "$kind" >&2
  printf '          %s lands via PR, never a local push; the Operator merges server-side. (--no-verify bypasses, visibly.)\n' \
    "${remote_ref#refs/heads/}" >&2
  exit 1
done

exit 0
